---
import Button from '../components/Button.astro';
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

interface ActionCard {
	title: string;
	description: string;
	cta: string;
	href: string;
}

interface ServiceCard {
	title: string;
	description: string;
	bullets: string[];
}

interface ValueCard {
	title: string;
	description: string;
}

interface Stat {
	value: string;
	label: string;
}

interface Step {
	number: string;
	title: string;
	description: string;
}

const actionCards: ActionCard[] = [
	{
		title: 'Get a Quote',
		description: 'Use our simplified quote request to send shipment details and receive a competitive rate from our team.',
		cta: 'Get a Quote',
		href: '#contact',
	},
	{
		title: 'Track a Shipment',
		description: 'Need help with shipment tracking? Our customer service team is available to assist with status updates.',
		cta: 'Track Now',
		href: '#contact',
	},
	{
		title: 'Request a P.O.D.',
		description: 'Need proof of delivery? Submit a request and our experienced personnel will help fulfill it.',
		cta: 'Send Request',
		href: '#contact',
	},
];

const services: ServiceCard[] = [
	{
		title: 'Hazmat Certified',
		description: 'Our drivers are skilled and professional, with hazmat and tanker endorsements for safe hazardous materials transportation.',
		bullets: ['Hazmat-ready operations', 'Tanker endorsements', 'Experienced safety-first drivers'],
	},
	{
		title: 'Refrigerated',
		description: 'Premium refrigerated units are expertly maintained and equipped for quality, reliability, and temperature-sensitive freight.',
		bullets: ['Well-maintained reefers', 'Temperature-sensitive freight', 'Reliable cold-chain support'],
	},
	{
		title: 'Team Drivers',
		description: 'Expedited services tailored for time-sensitive shipments, supported by team drivers focused on efficient delivery.',
		bullets: ['Expedited capability', 'Time-sensitive lanes', 'Efficient team-driver coverage'],
	},
	{
		title: 'All 48 States',
		description: 'Our fleet provides comprehensive coverage across all contiguous states, from regional moves to coast-to-coast freight.',
		bullets: ['Coast-to-coast lanes', '48-state coverage', 'Dependable round-the-clock service'],
	},
];

const valueCards: ValueCard[] = [
	{
		title: 'Dedication',
		description: 'We go above and beyond expectations for partners, owner operators, employees, and everyone we do business with.',
	},
	{
		title: 'Promise',
		description: 'We operate with dependable communication, well-maintained equipment, and a team that takes every shipment seriously.',
	},
	{
		title: 'Integrity',
		description: 'Prestige combines large-carrier capacity with the family values and moral standards of a smaller organization.',
	},
	{
		title: 'Customers',
		description: 'Our focus is long-term relationships built through reliable service, experienced staff, and accountable execution.',
	},
];

const stats: Stat[] = [
	{ value: '117', label: 'Active Trucks' },
	{ value: '7,860,144', label: 'Miles Hauled' },
	{ value: '1,056', label: 'Customers Served' },
	{ value: '10+', label: 'Years of Experience' },
];

const steps: Step[] = [
	{
		number: '01',
		title: 'Send Shipment Details',
		description: 'Tell us origin, destination, freight type, timing, and any special handling requirements.',
	},
	{
		number: '02',
		title: 'Match Equipment & Team',
		description: 'Prestige aligns the load with the right equipment, endorsements, capacity, and dispatch support.',
	},
	{
		number: '03',
		title: 'Move, Track & Confirm',
		description: 'Our team supports tracking, delivery updates, and proof-of-delivery requests from pickup to final paperwork.',
	},
];

const marqueeBadges: string[] = [
	'J.B. Hunt 2025 Hazmat Carrier of the Year',
	'Hazmat Certified',
	'Refrigerated Freight',
	'Team Drivers',
	'All 48 States',
	'117 Active Trucks',
	'24/7 Support',
	'100+ Power Units',
];

const marqueeItems = [...marqueeBadges, ...marqueeBadges];
---

<BaseLayout
	title="Prestige Transportation | Meeting Your Transportation Needs"
	description="Prestige Transportation provides hazmat certified, refrigerated, expedited team driver, and coast-to-coast freight service across all 48 contiguous states."
>
	<!-- Hero -->
	<section id="hero" aria-label="Hero" class="relative isolate overflow-hidden bg-brand-navy text-white">
		<div class="absolute inset-0 -z-10 bg-radial-glow" aria-hidden="true"></div>
		<div class="absolute inset-0 -z-10 bg-grid-faint opacity-50" aria-hidden="true"></div>
		<div class="absolute inset-x-0 top-0 -z-10 h-48 bg-gradient-to-b from-white/10 to-transparent" aria-hidden="true"></div>

		<div class="mx-auto grid max-w-7xl gap-12 px-6 pb-20 pt-20 sm:px-8 lg:grid-cols-[1.05fr_0.95fr] lg:px-10 lg:pb-28 lg:pt-28">
			<div class="flex flex-col justify-center">
				<span class="inline-flex w-fit items-center gap-2 rounded-full border border-brand-safety/40 bg-brand-safety/10 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.22em] text-brand-safety">
					<span class="inline-block h-2 w-2 rounded-full bg-brand-safety" aria-hidden="true"></span>
					Prestige Transportation
				</span>

				<p class="mt-7 text-5xl font-black uppercase leading-none tracking-tight text-white/10 sm:text-7xl lg:text-8xl" aria-hidden="true">
					Drive With Us
				</p>
				<h1 class="-mt-4 max-w-4xl text-4xl font-black uppercase leading-[1.02] tracking-tight sm:text-5xl lg:text-6xl">
					Meeting your <span class="text-brand-safety">transportation</span> needs with coast-to-coast reliability.
				</h1>

				<p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
					Our network of 100+ power units, well-maintained equipment, experienced drivers, and dependable staff gives Prestige the capability of a large carrier with the family values of a smaller one.
				</p>

				<div class="mt-8 flex flex-wrap items-center gap-3">
					<Button href="#contact" variant="primary">Get a Quote</Button>
					<Button href="#services" variant="secondary">Explore Services</Button>
					<a href="#careers" class="inline-flex items-center justify-center rounded-full border border-white/20 px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] text-white transition hover:border-brand-safety hover:text-brand-safety">
						Careers
					</a>
				</div>

				<div class="mt-8 inline-flex max-w-xl items-center gap-4 rounded-2xl border border-brand-safety/30 bg-brand-safety/[0.08] p-4">
					<span class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-brand-safety/20 text-brand-safety" aria-hidden="true">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M8 21h8" />
							<path d="M12 17v4" />
							<path d="M7 4h10v5a5 5 0 0 1-10 0Z" />
							<path d="M17 4h3v3a3 3 0 0 1-3 3" />
							<path d="M7 4H4v3a3 3 0 0 0 3 3" />
						</svg>
					</span>
					<div>
						<p class="text-[0.65rem] font-bold uppercase tracking-[0.22em] text-brand-safety">Award-Winning Service</p>
						<p class="mt-1 text-sm font-bold leading-snug text-white">J.B. Hunt 2025 Hazmat Carrier of the Year</p>
					</div>
				</div>
			</div>

			<aside class="grid gap-4 lg:min-h-[34rem]" aria-label="Prestige operations highlights">
				<div class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.04] p-7 shadow-freight backdrop-blur">
					<div class="absolute inset-0 bg-gradient-to-br from-brand-signal/20 via-transparent to-brand-safety/20" aria-hidden="true"></div>
					<div class="relative grid h-full content-between gap-12">
						<div class="flex items-start justify-between gap-6">
							<div>
								<p class="text-xs font-bold uppercase tracking-[0.22em] text-brand-mist">Current Capacity</p>
								<p class="mt-3 text-5xl font-black text-white">117</p>
								<p class="mt-1 text-sm uppercase tracking-[0.18em] text-slate-300">Active Trucks</p>
							</div>
							<span class="rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-emerald-300">48 States</span>
						</div>
						<div class="grid grid-cols-2 gap-4">
							<div class="rounded-2xl border border-white/10 bg-brand-navy/60 p-5">
								<p class="text-xs uppercase tracking-[0.18em] text-slate-400">Fleet</p>
								<p class="mt-2 text-lg font-bold text-white">100+ Power Units</p>
							</div>
							<div class="rounded-2xl border border-white/10 bg-brand-navy/60 p-5">
								<p class="text-xs uppercase tracking-[0.18em] text-slate-400">Coverage</p>
								<p class="mt-2 text-lg font-bold text-white">Coast to Coast</p>
							</div>
						</div>
					</div>
				</div>

				<div class="grid gap-4 sm:grid-cols-2">
					<div class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-6">
						<p class="text-xs font-bold uppercase tracking-[0.22em] text-brand-safety">Hazmat</p>
						<p class="mt-3 text-2xl font-black uppercase">Certified drivers</p>
					</div>
					<div class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-6">
						<p class="text-xs font-bold uppercase tracking-[0.22em] text-brand-signal">Reefer</p>
						<p class="mt-3 text-2xl font-black uppercase">Premium units</p>
					</div>
				</div>
			</aside>
		</div>
	</section>

	<!-- Quick action cards -->
	<section aria-labelledby="actions-heading" class="relative z-10 -mt-12 pb-12 text-brand-slate">
		<h2 id="actions-heading" class="sr-only">Quick transportation actions</h2>
		<div class="mx-auto grid max-w-7xl gap-5 px-6 sm:px-8 md:grid-cols-3 lg:px-10">
			{actionCards.map((card) => (
				<article class="group rounded-3xl border border-slate-200 bg-white p-7 shadow-freight transition hover:-translate-y-1 hover:border-brand-signal">
					<h3 class="text-3xl font-black uppercase leading-none tracking-tight text-brand-navy">{card.title}</h3>
					<p class="mt-4 min-h-20 leading-7 text-slate-600">{card.description}</p>
					<a class="mt-6 inline-flex items-center gap-2 text-sm font-black uppercase tracking-[0.18em] text-brand-blue transition group-hover:text-brand-navy" href={card.href}>
						{card.cta}
						<span aria-hidden="true">→</span>
					</a>
				</article>
			))}
		</div>
	</section>

	<!-- Marquee trust strip -->
	<section aria-label="Capabilities and recognition" class="border-y border-white/10 bg-brand-slate text-brand-mist">
		<div class="relative overflow-hidden py-5">
			<div class="marquee-track flex w-max items-center gap-12 whitespace-nowrap">
				{marqueeItems.map((item) => (
					<span class="flex items-center gap-3 text-xs font-bold uppercase tracking-[0.28em]">
						<span class="text-brand-safety">◆</span>
						{item}
					</span>
				))}
			</div>
			<div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-brand-slate to-transparent"></div>
			<div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-brand-slate to-transparent"></div>
		</div>
	</section>

	<!-- About -->
	<section id="about" aria-labelledby="about-heading" class="bg-white py-24 text-brand-slate">
		<div class="mx-auto grid max-w-7xl gap-12 px-6 sm:px-8 lg:grid-cols-[0.95fr_1.05fr] lg:px-10">
			<div>
				<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-safety">About Us</p>
				<h2 id="about-heading" class="mt-3 text-3xl font-black uppercase tracking-tight text-brand-navy sm:text-4xl lg:text-5xl">
					Prestige Transportation. Meeting your transportation needs.
				</h2>
			</div>
			<div class="space-y-6 text-lg leading-8 text-slate-600">
				<p>
					We pride ourselves in going above and beyond the expectations of our partners, owner operators, and employees. We focus on long-term relationships with everyone we do business with.
				</p>
				<p>
					Our network of 100+ power units, well-maintained equipment, experienced drivers, and staff gives us the benefit of operating like a large carrier while maintaining the strong family and moral values of a smaller one.
				</p>
				<p>
					We currently operate in all 48 states, and our dependable employees work around the clock to ensure reliable service. Don&rsquo;t settle for just anyone — go with Prestige.
				</p>
			</div>
		</div>

		<div class="mx-auto mt-14 grid max-w-7xl gap-5 px-6 sm:px-8 md:grid-cols-4 lg:px-10">
			{valueCards.map((card) => (
				<article class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
					<p class="text-sm font-black uppercase tracking-[0.2em] text-brand-blue">{card.title}</p>
					<p class="mt-4 text-sm leading-7 text-slate-600">{card.description}</p>
				</article>
			))}
		</div>
	</section>

	<!-- Stats -->
	<section aria-labelledby="stats-heading" class="relative isolate overflow-hidden bg-brand-navy py-20 text-white">
		<div class="absolute inset-0 -z-10 bg-grid-faint opacity-40" aria-hidden="true"></div>
		<div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-10">
			<div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
				<div>
					<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-safety">By the numbers</p>
					<h2 id="stats-heading" class="mt-3 text-3xl font-black uppercase tracking-tight sm:text-4xl">Built to move, ready to serve.</h2>
				</div>
				<p class="max-w-xl leading-7 text-slate-300">Scale, coverage, and experience that support dependable service across the contiguous United States.</p>
			</div>

			<dl class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
				{stats.map((stat) => (
					<div class="rounded-3xl border border-white/10 bg-white/[0.04] p-7 text-center">
						<dt class="text-xs font-bold uppercase tracking-[0.2em] text-slate-400">{stat.label}</dt>
						<dd class="mt-3 text-4xl font-black text-white lg:text-5xl">{stat.value}</dd>
					</div>
				))}
			</dl>
		</div>
	</section>

	<!-- Services -->
	<section id="services" aria-labelledby="services-heading" class="bg-slate-100 py-24 text-brand-slate">
		<div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-10">
			<div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
				<div class="max-w-3xl">
					<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-blue">Services Available</p>
					<h2 id="services-heading" class="mt-3 text-3xl font-black uppercase tracking-tight text-brand-navy sm:text-4xl lg:text-5xl">
						Hazmat, refrigerated, team drivers, coast to coast.
					</h2>
					<p class="mt-4 text-lg leading-8 text-slate-600">
						For all your transportation needs, Prestige Transportation is equipped to handle your request with precision and efficiency.
					</p>
				</div>
				<Button href="#contact" variant="primary" class="self-start md:self-end">Request Capacity</Button>
			</div>

			<div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
				{services.map((service) => (
					<article class="group relative flex flex-col overflow-hidden rounded-3xl border border-slate-200 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:border-brand-signal hover:shadow-freight">
						<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-navy text-brand-safety ring-1 ring-brand-navy/10" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M3 7h11v9H3z" />
								<path d="M14 10h4l3 3v3h-7z" />
								<circle cx="7" cy="18" r="2" />
								<circle cx="17" cy="18" r="2" />
							</svg>
						</div>

						<h3 class="mt-5 text-xl font-black uppercase text-brand-navy">{service.title}</h3>
						<p class="mt-3 leading-7 text-slate-600">{service.description}</p>

						<ul class="mt-5 space-y-2 text-sm text-slate-600">
							{service.bullets.map((bullet) => (
								<li class="flex items-start gap-2">
									<span class="mt-2 inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-safety" aria-hidden="true"></span>
									{bullet}
								</li>
							))}
						</ul>

						<a class="mt-6 inline-flex items-center gap-2 text-sm font-bold uppercase tracking-[0.18em] text-brand-blue transition group-hover:text-brand-navy" href="#contact">
							Get a Quote
							<span aria-hidden="true">→</span>
						</a>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- Equipment / safety inspired split -->
	<section id="equipment" aria-labelledby="equipment-heading" class="bg-white py-24 text-brand-slate">
		<div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-10">
			<div class="grid gap-6 lg:grid-cols-[1fr_0.8fr_1fr] lg:items-stretch">
				<article class="rounded-[2rem] border border-slate-200 bg-slate-50 p-8">
					<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-blue">The Vehicle</p>
					<h3 class="mt-4 text-3xl font-black uppercase tracking-tight text-brand-navy">Well-maintained equipment</h3>
					<p class="mt-4 leading-8 text-slate-600">
						Our premium refrigerated units and fleet equipment are maintained to support transportation needs with high standards of quality and reliability.
					</p>
				</article>

				<div class="flex min-h-72 items-center justify-center rounded-[2rem] bg-brand-navy p-8 text-center text-white shadow-freight">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-safety">The Equipment</p>
						<h2 id="equipment-heading" class="mt-4 text-4xl font-black uppercase tracking-tight">Large carrier capability. Family carrier values.</h2>
					</div>
				</div>

				<article class="rounded-[2rem] border border-slate-200 bg-slate-50 p-8">
					<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-blue">Safety</p>
					<h3 class="mt-4 text-3xl font-black uppercase tracking-tight text-brand-navy">Hazmat and tanker expertise</h3>
					<p class="mt-4 leading-8 text-slate-600">
						Our drivers bring experience and endorsements to safely and effectively manage hazardous materials and demanding freight requirements.
					</p>
				</article>
			</div>
		</div>
	</section>

	<!-- Process -->
	<section id="process" aria-labelledby="process-heading" class="relative isolate overflow-hidden bg-brand-navy py-24 text-white">
		<div class="absolute inset-0 -z-10 bg-grid-faint opacity-50" aria-hidden="true"></div>
		<div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-10">
			<div class="max-w-3xl">
				<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-safety">How It Works</p>
				<h2 id="process-heading" class="mt-3 text-3xl font-black uppercase tracking-tight sm:text-4xl lg:text-5xl">
					Quote, dispatch, track, confirm.
				</h2>
				<p class="mt-4 text-lg leading-8 text-slate-300">
					A straightforward workflow for quotes, tracking assistance, and proof-of-delivery support.
				</p>
			</div>

			<ol class="mt-12 grid gap-6 md:grid-cols-3">
				{steps.map((step) => (
					<li class="relative rounded-3xl border border-white/10 bg-white/[0.04] p-7 backdrop-blur">
						<span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brand-safety text-sm font-black text-brand-navy">
							{step.number}
						</span>
						<h3 class="mt-5 text-xl font-bold text-white">{step.title}</h3>
						<p class="mt-3 leading-7 text-slate-300">{step.description}</p>
					</li>
				))}
			</ol>
		</div>
	</section>

	<!-- Careers -->
	<section id="careers" aria-labelledby="careers-heading" class="bg-slate-100 py-24 text-brand-slate">
		<div class="mx-auto grid max-w-7xl gap-10 px-6 sm:px-8 lg:grid-cols-[1fr_0.9fr] lg:px-10">
			<div>
				<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-blue">Careers</p>
				<h2 id="careers-heading" class="mt-3 text-3xl font-black uppercase tracking-tight text-brand-navy sm:text-4xl lg:text-5xl">
					Drive with Prestige. Build with people who value long-term relationships.
				</h2>
				<p class="mt-5 text-lg leading-8 text-slate-600">
					Prestige focuses on partners, owner operators, and employees. Our team works around the clock to support dependable service across all 48 states.
				</p>
			</div>
			<div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
				<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-safety">Why drivers choose Prestige</p>
				<ul class="mt-6 space-y-4 text-sm leading-7 text-slate-600">
					<li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-brand-safety" aria-hidden="true"></span>Experienced dispatch and operations support</li>
					<li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-brand-safety" aria-hidden="true"></span>Hazmat, refrigerated, team-driver, and coast-to-coast opportunities</li>
					<li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-brand-safety" aria-hidden="true"></span>Family values with large-carrier operating capability</li>
				</ul>
				<div class="mt-8">
					<Button href="#contact" variant="primary">Contact Recruiting</Button>
				</div>
			</div>
		</div>
	</section>

	<!-- Final CTA banner -->
	<section aria-label="Call to action" class="relative isolate overflow-hidden bg-brand-slate text-white">
		<div class="absolute inset-0 -z-10 bg-radial-glow opacity-80" aria-hidden="true"></div>
		<div class="mx-auto flex max-w-7xl flex-col items-start gap-8 px-6 py-20 sm:px-8 md:flex-row md:items-center md:justify-between lg:px-10">
			<div class="max-w-2xl">
				<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-safety">Get a Quote</p>
				<h2 class="mt-3 text-3xl font-black uppercase tracking-tight sm:text-4xl">
					Contact us today for all your transportation needs.
				</h2>
				<p class="mt-4 text-base leading-8 text-slate-300">
					Prestige Transportation is equipped to handle your request with precision and efficiency. We look forward to the opportunity to work with you.
				</p>
			</div>
			<div class="flex flex-wrap gap-3">
				<Button href="#contact" variant="primary">Request Quote</Button>
				<Button href="#services" variant="secondary">View Services</Button>
			</div>
		</div>
	</section>

	<!-- Contact -->
