---
import Button from '../components/Button.astro';
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

interface ServiceCard {
	title: string;
	description: string;
}

const services: ServiceCard[] = [
	{
		title: 'Truckload Freight',
		description: 'Structured capacity planning for point-to-point commercial freight moves.',
	},
	{
		title: 'Expedited Logistics',
		description: 'Responsive shipment coordination for freight that requires tighter timelines.',
	},
	{
		title: 'Shipment Support',
		description: 'Clear intake, routing, and communication workflows for transportation requests.',
	},
];
---

<BaseLayout
	title="Prestige, Inc. | Transportation & Logistics"
	description="A static transportation and logistics website scaffold for Prestige, Inc. with A2P 10DLC-ready compliance language."
>
	<section id="hero" aria-label="Hero" class="border-b border-white/10 bg-brand-navy">
		<div class="mx-auto min-h-[28rem] max-w-7xl px-6 py-24 sm:px-8 lg:px-10">
			<!-- Hero content placeholder intentionally left empty for final brand messaging. -->
		</div>
	</section>

	<section id="services" aria-labelledby="services-heading" class="bg-white py-20 text-brand-slate">
		<div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-10">
			<div class="max-w-3xl">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-safety">Services</p>
				<h1 id="services-heading" class="mt-3 text-3xl font-bold tracking-tight text-brand-navy sm:text-4xl">
					Transportation support built for freight operations
				</h1>
				<p class="mt-4 text-lg leading-8 text-slate-600">
					A modular service area ready for final copy, lane details, and operational differentiators.
				</p>
			</div>

			<div class="mt-12 grid gap-6 md:grid-cols-3">
				{services.map((service) => (
					<article class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition hover:-translate-y-1 hover:border-brand-signal hover:shadow-lg">
						<div class="mb-5 h-12 w-12 rounded-xl bg-brand-navy text-brand-safety ring-1 ring-brand-navy/10" aria-hidden="true"></div>
						<h2 class="text-xl font-bold text-brand-navy">{service.title}</h2>
						<p class="mt-3 leading-7 text-slate-600">{service.description}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section id="contact" aria-labelledby="contact-heading" class="bg-slate-100 py-20 text-brand-slate">
		<div class="mx-auto grid max-w-7xl gap-10 px-6 sm:px-8 lg:grid-cols-[0.9fr_1.1fr] lg:px-10">
			<div>
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-blue">Request a quote</p>
				<h2 id="contact-heading" class="mt-3 text-3xl font-bold tracking-tight text-brand-navy sm:text-4xl">
					Start a shipment conversation
				</h2>
				<p class="mt-4 text-lg leading-8 text-slate-600">
					The form is structured for lead intake and includes explicit SMS consent language required for A2P 10DLC review.
				</p>
				<div class="mt-8">
					<Button href="#" variant="secondary">View service overview</Button>
				</div>
			</div>

			<ContactForm />
		</div>
	</section>
</BaseLayout>
