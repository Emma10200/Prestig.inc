---
import Button from '../components/Button.astro';
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

interface ServiceCard {
	title: string;
	description: string;
	bullets: string[];
}

interface Pillar {
	title: string;
	description: string;
}

interface Stat {
	value: string;
	label: string;
}

interface Testimonial {
	quote: string;
	name: string;
	role: string;
}

interface Step {
	number: string;
	title: string;
	description: string;
}

const services: ServiceCard[] = [
	{
		title: 'Truckload Freight',
		description: 'Reliable point-to-point capacity for full truckload shipments across the lower 48.',
		bullets: ['Dry van capacity', 'Asset-based options', '48-state coverage'],
	},
	{
		title: 'Expedited Logistics',
		description: 'Time-critical freight handled with priority dispatch and proactive status updates.',
		bullets: ['Team driver options', 'Tight transit windows', 'Live communication'],
	},
	{
		title: 'Dedicated Capacity',
		description: 'Consistent equipment and drivers reserved for recurring lanes and high-volume customers.',
		bullets: ['Predictable scheduling', 'Lane-specific planning', 'Long-term partnerships'],
	},
	{
		title: 'Refrigerated Freight',
		description: 'Temperature-controlled transportation for foods, beverages, and sensitive products.',
		bullets: ['Reefer trailers', 'Temperature monitoring', 'Cold-chain handoffs'],
	},
	{
		title: 'High-Value Cargo',
		description: 'Enhanced handling and security protocols for shipments that demand extra care.',
		bullets: ['Secure routing', 'Verified drivers', 'Chain-of-custody focus'],
	},
	{
		title: 'Dry Freight',
		description: 'Cost-effective transport for general cargo that does not require special handling.',
		bullets: ['Standard dry van', 'Flexible scheduling', 'Nationwide lanes'],
	},
];

const pillars: Pillar[] = [
	{
		title: 'Safety First, Always',
		description: 'Compliance-driven operations with strict driver vetting, training, and equipment standards.',
	},
	{
		title: 'Operations You Can Reach',
		description: 'A real dispatch team that answers the phone and keeps shippers informed end-to-end.',
	},
	{
		title: '48-State Coverage',
		description: 'Coast-to-coast lanes with capacity options for both one-off shipments and recurring freight.',
	},
	{
		title: 'Built for Partnership',
		description: 'We focus on long-term relationships with shippers, drivers, vendors, and partners.',
	},
];

const stats: Stat[] = [
	{ value: '48', label: 'States Served' },
	{ value: '24/7', label: 'Dispatch Support' },
	{ value: '100%', label: 'DOT Compliant' },
	{ value: '1 Day', label: 'Quote Turnaround' },
];

const steps: Step[] = [
	{
		number: '01',
		title: 'Request a Quote',
		description: 'Share shipment details through the form, by phone, or by email and our team confirms the same business day.',
	},
	{
		number: '02',
		title: 'Capacity Confirmed',
		description: 'We match the freight with the right equipment, qualified drivers, and a realistic transit plan.',
	},
	{
		number: '03',
		title: 'Tracked Delivery',
		description: 'Active communication from pickup to delivery, with proof of delivery and a clean handoff.',
	},
];

const testimonials: Testimonial[] = [
	{
		quote: 'Their dispatch team actually answers the phone. Communication, scheduling, and follow-through have been consistent every single load.',
		name: 'Shipping Manager',
		role: 'Regional Manufacturer',
	},
	{
		quote: 'Clear pickup windows, reliable equipment, and clean paperwork. They handle our freight like it is their own business on the line.',
		name: 'Logistics Coordinator',
		role: 'Consumer Goods Brand',
	},
	{
		quote: 'They were straightforward from the first call. Fair rates, no surprises, and they kept us informed through transit and delivery.',
		name: 'Operations Lead',
		role: 'Distribution Partner',
	},
];

const marqueeBadges: string[] = [
	'DOT Authorized',
	'MC Authority',
	'48 Contiguous States',
	'24/7 Dispatch',
	'Asset-Backed Options',
	'On-Time Delivery Focus',
	'Truckload · Expedited · Dedicated',
	'A2P 10DLC Ready Communications',
];

const marqueeItems = [...marqueeBadges, ...marqueeBadges];
---

<BaseLayout
	title="Prestige, Inc. | Transportation & Logistics"
	description="Prestige, Inc. is a transportation and logistics provider delivering truckload, expedited, dedicated, and refrigerated freight across the 48 contiguous states."
>
	<!-- Hero -->
	<section id="hero" aria-label="Hero" class="relative isolate overflow-hidden bg-brand-navy text-white">
		<div class="absolute inset-0 -z-10 bg-radial-glow" aria-hidden="true"></div>
		<div class="absolute inset-0 -z-10 bg-grid-faint opacity-60" aria-hidden="true"></div>

		<div class="mx-auto grid max-w-7xl gap-12 px-6 pb-24 pt-20 sm:px-8 lg:grid-cols-[1.15fr_0.85fr] lg:px-10 lg:pt-28">
			<div class="flex flex-col justify-center">
				<span class="inline-flex w-fit items-center gap-2 rounded-full border border-brand-safety/40 bg-brand-safety/10 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.22em] text-brand-safety">
					<span class="inline-block h-2 w-2 rounded-full bg-brand-safety" aria-hidden="true"></span>
					Transportation &amp; Logistics
				</span>

				<h1 class="mt-6 text-4xl font-black uppercase leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
					Freight moved with <span class="text-brand-safety">precision</span>,<br class="hidden sm:inline" />
					delivered with <span class="text-brand-signal">accountability</span>.
				</h1>

				<p class="mt-6 max-w-xl text-lg leading-8 text-slate-300">
					Prestige, Inc. is a transportation and logistics provider serving shippers across the lower 48. We focus on safe, on-time freight movement and clear communication from quote to delivery.
				</p>

				<div class="mt-8 inline-flex max-w-xl items-center gap-4 rounded-2xl border border-brand-safety/30 bg-brand-safety/[0.08] p-4">
					<span class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-brand-safety/20 text-brand-safety" aria-hidden="true">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M8 21h8" />
							<path d="M12 17v4" />
							<path d="M7 4h10v5a5 5 0 0 1-10 0Z" />
							<path d="M17 4h3v3a3 3 0 0 1-3 3" />
							<path d="M7 4H4v3a3 3 0 0 0 3 3" />
						</svg>
					</span>
					<div>
						<p class="text-[0.65rem] font-bold uppercase tracking-[0.22em] text-brand-safety">Award-Winning Service</p>
						<p class="mt-1 text-sm font-bold leading-snug text-white">J.B. Hunt 2025 Hazmat Carrier of the Year</p>
					</div>
				</div>

				<div class="mt-8 flex flex-wrap items-center gap-3">
					<Button href="#contact" variant="primary">Get a Quote</Button>
					<Button href="#services" variant="secondary">View Services</Button>
				</div>

				<dl class="mt-12 grid max-w-xl grid-cols-2 gap-y-6 border-t border-white/10 pt-8 sm:grid-cols-4">
					{stats.map((stat) => (
						<div>
							<dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">{stat.label}</dt>
							<dd class="mt-2 text-2xl font-black text-white sm:text-3xl">{stat.value}</dd>
						</div>
					))}
				</dl>
			</div>

			<aside class="relative hidden lg:block" aria-hidden="true">
				<div class="absolute inset-0 rounded-[2rem] bg-gradient-to-br from-brand-blue/40 via-brand-navy to-brand-slate ring-1 ring-white/10"></div>
				<div class="relative flex h-full flex-col justify-between rounded-[2rem] p-8">
					<div class="flex items-center justify-between">
						<span class="text-xs font-bold uppercase tracking-[0.22em] text-brand-mist">Active Lane</span>
						<span class="inline-flex items-center gap-2 rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-emerald-300">
							<span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
							On Schedule
						</span>
					</div>

					<div class="mt-12 space-y-6">
						<div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
							<p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Origin</p>
							<p class="mt-1 text-xl font-bold text-white">Chicago, IL</p>
						</div>
						<div class="flex items-center gap-3 text-brand-safety">
							<span class="h-px flex-1 bg-white/10"></span>
							<span class="text-xs font-bold uppercase tracking-[0.22em]">In Transit</span>
							<span class="h-px flex-1 bg-white/10"></span>
						</div>
						<div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
							<p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Destination</p>
							<p class="mt-1 text-xl font-bold text-white">Dallas, TX</p>
						</div>
					</div>

					<div class="mt-10 grid grid-cols-3 gap-3 text-center">
						<div class="rounded-xl border border-white/10 bg-white/[0.04] py-3">
							<p class="text-xs uppercase tracking-[0.18em] text-slate-400">ETA</p>
							<p class="mt-1 text-sm font-bold text-white">~18h</p>
						</div>
						<div class="rounded-xl border border-white/10 bg-white/[0.04] py-3">
							<p class="text-xs uppercase tracking-[0.18em] text-slate-400">Miles</p>
							<p class="mt-1 text-sm font-bold text-white">925</p>
						</div>
						<div class="rounded-xl border border-white/10 bg-white/[0.04] py-3">
							<p class="text-xs uppercase tracking-[0.18em] text-slate-400">Status</p>
							<p class="mt-1 text-sm font-bold text-emerald-300">Live</p>
						</div>
					</div>
				</div>
			</aside>
		</div>
	</section>

	<!-- Marquee compliance/trust strip -->
	<section aria-label="Authorities and capabilities" class="border-y border-white/10 bg-brand-slate text-brand-mist">
		<div class="relative overflow-hidden py-5">
			<div class="marquee-track flex w-max items-center gap-12 whitespace-nowrap">
				{marqueeItems.map((item) => (
					<span class="flex items-center gap-3 text-xs font-bold uppercase tracking-[0.28em]">
						<span class="text-brand-safety">◆</span>
						{item}
					</span>
				))}
			</div>
			<div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-brand-slate to-transparent"></div>
			<div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-brand-slate to-transparent"></div>
		</div>
	</section>

	<!-- Award callout -->
	<section aria-label="Industry recognition" class="bg-white py-12 text-brand-slate">
		<div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-10">
			<div class="flex flex-col items-start gap-6 rounded-3xl border border-slate-200 bg-gradient-to-br from-slate-50 via-white to-slate-50 p-8 md:flex-row md:items-center md:justify-between md:p-10">
				<div class="flex items-center gap-5">
					<span class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-2xl bg-brand-navy text-brand-safety ring-1 ring-brand-navy/10" aria-hidden="true">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M8 21h8" />
							<path d="M12 17v4" />
							<path d="M7 4h10v5a5 5 0 0 1-10 0Z" />
							<path d="M17 4h3v3a3 3 0 0 1-3 3" />
							<path d="M7 4H4v3a3 3 0 0 0 3 3" />
						</svg>
					</span>
					<div>
						<p class="text-xs font-bold uppercase tracking-[0.22em] text-brand-safety">2025 Industry Recognition</p>
						<p class="mt-2 text-xl font-black uppercase tracking-tight text-brand-navy sm:text-2xl">
							J.B. Hunt Hazmat Carrier of the Year
						</p>
						<p class="mt-2 max-w-2xl text-sm leading-7 text-slate-600">
							Recognized by J.B. Hunt for safety, service, and execution in hazardous materials transportation.
						</p>
					</div>
				</div>
				<Button href="#contact" variant="primary">Move Hazmat With Us</Button>
			</div>
		</div>
	</section>

	<!-- Services -->
	<section id="services" aria-labelledby="services-heading" class="bg-white py-24 text-brand-slate">
		<div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-10">
			<div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
				<div class="max-w-3xl">
					<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-safety">Services</p>
					<h2 id="services-heading" class="mt-3 text-3xl font-black uppercase tracking-tight text-brand-navy sm:text-4xl lg:text-5xl">
						Freight solutions for every shipment
					</h2>
					<p class="mt-4 text-lg leading-8 text-slate-600">
						From standard dry van to dedicated lanes and temperature-controlled freight, Prestige, Inc. structures the right capacity around each customer&rsquo;s shipment requirements.
					</p>
				</div>
				<Button href="#contact" variant="primary" class="self-start md:self-end">Request Capacity</Button>
			</div>

			<div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				{services.map((service) => (
					<article class="group relative flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 p-7 transition hover:-translate-y-1 hover:border-brand-signal hover:shadow-freight">
						<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-navy text-brand-safety ring-1 ring-brand-navy/10" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M3 7h11v9H3z" />
								<path d="M14 10h4l3 3v3h-7z" />
								<circle cx="7" cy="18" r="2" />
								<circle cx="17" cy="18" r="2" />
							</svg>
						</div>

						<h3 class="mt-5 text-xl font-bold text-brand-navy">{service.title}</h3>
						<p class="mt-3 leading-7 text-slate-600">{service.description}</p>

						<ul class="mt-5 space-y-2 text-sm text-slate-600">
							{service.bullets.map((bullet) => (
								<li class="flex items-start gap-2">
									<span class="mt-2 inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-safety" aria-hidden="true"></span>
									{bullet}
								</li>
							))}
						</ul>

						<a class="mt-6 inline-flex items-center gap-2 text-sm font-bold uppercase tracking-[0.18em] text-brand-blue transition group-hover:text-brand-navy" href="#contact">
							Get a Quote
							<span aria-hidden="true">→</span>
						</a>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- Why choose us -->
	<section id="why" aria-labelledby="why-heading" class="relative isolate overflow-hidden bg-brand-navy py-24 text-white">
		<div class="absolute inset-0 -z-10 bg-grid-faint opacity-50" aria-hidden="true"></div>
		<div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-10">
			<div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr]">
				<div>
					<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-safety">Why Prestige</p>
					<h2 id="why-heading" class="mt-3 text-3xl font-black uppercase tracking-tight sm:text-4xl lg:text-5xl">
						Built around safety, accountability, and execution
					</h2>
					<p class="mt-5 max-w-md text-base leading-8 text-slate-300">
						Transportation is operationally intense. Our process is designed so shippers know exactly where their freight stands and what to expect next.
					</p>
					<div class="mt-8">
						<Button href="#contact" variant="primary">Talk to Operations</Button>
					</div>
				</div>

				<div class="grid gap-5 sm:grid-cols-2">
					{pillars.map((pillar) => (
						<article class="rounded-2xl border border-white/10 bg-white/[0.04] p-6 backdrop-blur transition hover:border-brand-safety/50">
							<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-safety/15 text-brand-safety" aria-hidden="true">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6Z" />
								</svg>
							</div>
							<h3 class="mt-4 text-lg font-bold">{pillar.title}</h3>
							<p class="mt-2 text-sm leading-7 text-slate-300">{pillar.description}</p>
						</article>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- Process / How it works -->
	<section id="process" aria-labelledby="process-heading" class="bg-slate-100 py-24 text-brand-slate">
		<div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-10">
			<div class="max-w-3xl">
				<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-blue">How It Works</p>
				<h2 id="process-heading" class="mt-3 text-3xl font-black uppercase tracking-tight text-brand-navy sm:text-4xl lg:text-5xl">
					A clean, predictable shipment workflow
				</h2>
				<p class="mt-4 text-lg leading-8 text-slate-600">
					Three steps from inquiry to delivery, designed to remove ambiguity from your freight planning.
				</p>
			</div>

			<ol class="mt-12 grid gap-6 md:grid-cols-3">
				{steps.map((step) => (
					<li class="relative rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
						<span class="absolute -top-4 left-7 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-brand-navy text-sm font-black text-brand-safety ring-4 ring-slate-100">
							{step.number}
						</span>
						<h3 class="mt-4 text-xl font-bold text-brand-navy">{step.title}</h3>
						<p class="mt-3 leading-7 text-slate-600">{step.description}</p>
					</li>
				))}
			</ol>
		</div>
	</section>

	<!-- Testimonials -->
	<section id="testimonials" aria-labelledby="testimonials-heading" class="bg-white py-24 text-brand-slate">
		<div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-10">
			<div class="max-w-3xl">
				<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-safety">What Partners Say</p>
				<h2 id="testimonials-heading" class="mt-3 text-3xl font-black uppercase tracking-tight text-brand-navy sm:text-4xl lg:text-5xl">
					Trusted by shippers who need consistency
				</h2>
				<p class="mt-4 text-lg leading-8 text-slate-600">
					Placeholder testimonials shown for layout. Replace with verified shipper or partner quotes before launch.
				</p>
			</div>

			<div class="mt-12 grid gap-6 md:grid-cols-3">
				{testimonials.map((testimonial) => (
					<figure class="flex h-full flex-col justify-between rounded-2xl border border-slate-200 bg-slate-50 p-7">
						<div>
							<div class="flex gap-1 text-brand-safety" aria-hidden="true">
								{Array.from({ length: 5 }).map(() => (
									<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
										<path d="m12 2 2.9 6.9L22 10l-5.5 4.8L18.2 22 12 18.3 5.8 22l1.7-7.2L2 10l7.1-1.1Z" />
									</svg>
								))}
							</div>
							<blockquote class="mt-4 text-base leading-7 text-slate-700">
								&ldquo;{testimonial.quote}&rdquo;
							</blockquote>
						</div>
						<figcaption class="mt-6 border-t border-slate-200 pt-4">
							<p class="text-sm font-bold uppercase tracking-[0.16em] text-brand-navy">{testimonial.name}</p>
							<p class="mt-1 text-xs uppercase tracking-[0.18em] text-slate-500">{testimonial.role}</p>
						</figcaption>
					</figure>
				))}
			</div>
		</div>
	</section>

	<!-- Final CTA banner -->
	<section aria-label="Call to action" class="relative isolate overflow-hidden bg-brand-slate text-white">
		<div class="absolute inset-0 -z-10 bg-radial-glow opacity-80" aria-hidden="true"></div>
		<div class="mx-auto flex max-w-7xl flex-col items-start gap-8 px-6 py-20 sm:px-8 md:flex-row md:items-center md:justify-between lg:px-10">
			<div class="max-w-2xl">
				<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-safety">Ready to move freight?</p>
				<h2 class="mt-3 text-3xl font-black uppercase tracking-tight sm:text-4xl">
					Get a quote from a team that picks up the phone.
				</h2>
				<p class="mt-4 text-base leading-8 text-slate-300">
					Share shipment details and our team will respond the same business day with capacity, lane, and pricing options.
				</p>
			</div>
			<div class="flex flex-wrap gap-3">
				<Button href="#contact" variant="primary">Request Quote</Button>
				<Button href="#services" variant="secondary">View Services</Button>
			</div>
		</div>
	</section>

	<!-- Contact -->
	<section id="contact" aria-labelledby="contact-heading" class="bg-slate-100 py-24 text-brand-slate">
		<div class="mx-auto grid max-w-7xl gap-10 px-6 sm:px-8 lg:grid-cols-[0.9fr_1.1fr] lg:px-10">
			<div>
				<p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-blue">Request a Quote</p>
				<h2 id="contact-heading" class="mt-3 text-3xl font-black uppercase tracking-tight text-brand-navy sm:text-4xl lg:text-5xl">
					Start a shipment conversation
				</h2>
				<p class="mt-4 text-lg leading-8 text-slate-600">
					The form is structured for lead intake and includes the explicit SMS consent language required for A2P 10DLC review.
				</p>

				<ul class="mt-8 space-y-4 text-sm leading-7 text-slate-600">
					<li class="flex items-start gap-3">
						<span class="mt-1 inline-flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-brand-safety/15 text-brand-safety" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7" /></svg>
						</span>
						Same business day response from our operations team
					</li>
					<li class="flex items-start gap-3">
