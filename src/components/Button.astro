---
export interface Props {
	href: string;
	variant?: 'primary' | 'secondary';
	class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const variants: Record<NonNullable<Props['variant']>, string> = {
	primary: 'bg-brand-safety text-brand-navy hover:bg-sky-300 focus-visible:outline-brand-safety',
	secondary: 'border border-brand-navy/20 bg-white text-brand-navy hover:border-brand-signal hover:text-brand-blue',
};
---

<a
	href={href}
	class:list={[
		'inline-flex items-center justify-center rounded-full px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] shadow-sm transition',
		variants[variant],
		className,
	]}
>
	<slot />
</a>