---
interface FooterLink {
	href: string;
	label: string;
}

const legalLinks: FooterLink[] = [
	{ href: '/#contact', label: 'Get a Quote' },
	{ href: '/#contact', label: 'Track a Shipment' },
	{ href: '/#contact', label: 'Request P.O.D.' },
	{ href: '/#careers', label: 'Careers' },
	{ href: '/privacy', label: 'Privacy Policy' },
	{ href: '/terms', label: 'Terms of Service' },
];

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-white/10 bg-brand-slate text-slate-300">
	<div class="mx-auto flex max-w-7xl flex-col gap-8 px-6 py-10 sm:px-8 md:flex-row md:items-center md:justify-between lg:px-10">
		<div>
			<p class="text-lg font-bold text-white">Prestige Transportation</p>
			<p class="mt-2 max-w-xl text-sm leading-6 text-slate-400">
				Hazmat certified, refrigerated, team-driver, and coast-to-coast transportation support with audit-ready privacy, terms, and SMS consent structure.
			</p>
		</div>

		<nav aria-label="Legal links" class="flex flex-wrap gap-x-6 gap-y-3 text-sm font-semibold">
			{legalLinks.map((link) => (
				<a class="transition hover:text-brand-safety" href={link.href}>{link.label}</a>
			))}
		</nav>
	</div>

	<div class="border-t border-white/10 px-6 py-5 text-center text-xs text-slate-500 sm:px-8 lg:px-10">
		<p>&copy; {currentYear} Prestige, Inc. All rights reserved.</p>
	</div>
</footer>