---
import Button from './Button.astro';

interface NavLink {
	href: string;
	label: string;
}

const navLinks: NavLink[] = [
	{ href: '#services', label: 'Services' },
	{ href: '#contact', label: 'Request Quote' },
	{ href: '/privacy', label: 'Privacy' },
	{ href: '/terms', label: 'Terms' },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-brand-navy/95 text-white shadow-lg shadow-slate-950/20 backdrop-blur">
	<div class="mx-auto flex max-w-7xl flex-col gap-4 px-6 py-4 sm:px-8 md:flex-row md:items-center md:justify-between lg:px-10">
		<a href="/" class="inline-flex items-center gap-3" aria-label="Prestige, Inc. home">
			<span class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-safety text-sm font-black text-brand-navy">PI</span>
			<span>
				<span class="block text-lg font-bold leading-none">Prestige, Inc.</span>
				<span class="mt-1 block text-xs font-semibold uppercase tracking-[0.2em] text-brand-mist">Logistics</span>
			</span>
		</a>

		<nav aria-label="Primary navigation" class="flex flex-wrap items-center gap-x-5 gap-y-3 text-sm font-semibold text-slate-200">
			{navLinks.map((link) => (
				<a class="transition hover:text-brand-safety" href={link.href}>{link.label}</a>
			))}
			<Button href="#contact" class="hidden md:inline-flex">Quote</Button>
		</nav>
	</div>
</header>