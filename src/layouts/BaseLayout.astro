---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';

export interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Prestige, Inc. | Transportation & Logistics',
	description = 'Transportation and logistics website for Prestige, Inc.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body>
		<a class="sr-only focus:not-sr-only focus:absolute focus:left-6 focus:top-6 focus:z-[60] focus:rounded-full focus:bg-brand-safety focus:px-4 focus:py-2 focus:text-sm focus:font-bold focus:text-brand-navy" href="#main-content">
			Skip to main content
		</a>
		<Header />
		<main id="main-content">
			<slot />
		</main>
		<Footer />
	</body>
</html>