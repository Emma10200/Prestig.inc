{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "prestig-inc",
	"compatibility_date": "2026-05-18",
	"assets": {
		"directory": "./dist"
	},
	"routes": [
		{
			"pattern": "prestige.inc",
			"custom_domain": true
		},
		{
			"pattern": "www.prestige.inc",
			"custom_domain": true
		}
	]
}
